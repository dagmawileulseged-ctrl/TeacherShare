# PostgreSQL Database Connection URL (e.g., Supabase PostgreSQL, Neon, AWS RDS, or Local Postgres)
DATABASE_URL="postgresql://username:password@hostname:5432/databasename"

# Supabase Storage Configuration (Required for Production File Uploads)
# To obtain these, log in to your Supabase project dashboard -> Project Settings -> API.
SUPABASE_URL="https://your-supabase-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-public-api-key"

# Supabase Storage Bucket Name (Defaults to "materials")
SUPABASE_BUCKET_NAME="materials"

# Resend API Key (Optional for development, required for production email sending)
# Sign up at resend.com to get your API key.
RESEND_API_KEY="your-resend-api-key"

# Resend From Email (Optional. Defaults to "TeacherShare <onboarding@resend.dev>")
# Once you verify your domain on Resend, set this to your verified email address.
RESEND_FROM_EMAIL="TeacherShare <no-reply@yourdomain.com>"

# SMTP Configuration (Optional for development, required for production email sending if not using Resend)
# To use Gmail, set host to "smtp.gmail.com", port to 465, and password to your Google App Password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-google-app-password"
