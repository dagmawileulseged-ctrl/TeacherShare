# PostgreSQL Database Connection URL (e.g., Supabase PostgreSQL, Neon, AWS RDS, or Local Postgres)
DATABASE_URL="postgresql://username:password@hostname:5432/databasename"

# Supabase Storage Configuration (Required for Production File Uploads)
# To obtain these, log in to your Supabase project dashboard -> Project Settings -> API.
SUPABASE_URL="https://your-supabase-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-public-api-key"

# Supabase Storage Bucket Name (Defaults to "materials")
SUPABASE_BUCKET_NAME="materials"
